########################################
# Oasis .env.local
# Copy: cp .env.local.example .env.local
# Fill required vars. See README.md for setup.
########################################

###########################
# Supabase (required)
###########################
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

###########################
# Admin (required)
###########################
ADMIN_EMAILS=admin@example.com

###########################
# Weather (Tomorrow.io – required for triggers)
###########################
TOMORROW_IO_API_KEY=

###########################
# News (NewsData.io – required for triggers)
###########################
NEWSDATA_IO_API_KEY=

###########################
# Traffic (TomTom – optional, real-time gridlock/closure triggers)
###########################
# Get key: https://developer.tomtom.com/ → create app → API key (2,500 free requests/day)
TOMTOM_API_KEY=

###########################
# AQI (optional – fallback to Open-Meteo)
###########################
WAQI_API_KEY=

###########################
# AI (OpenRouter – adjudication, gov ID verification)
###########################
OPENROUTER_API_KEY=

###########################
# Payments (Razorpay — test mode only; Key Id must start with rzp_test_)
###########################
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional but recommended: payment.captured webhook at /api/payments/webhook
RAZORPAY_WEBHOOK_SECRET=

###########################
# Cron (required in production)
###########################
CRON_SECRET=

###########################
# Rate limiting (optional)
###########################
# Defaults to in-memory to avoid one Supabase RPC per guarded request.
# Set true only if you need distributed limits across many app instances.
# SUPABASE_RATE_LIMIT_STORE=false

###########################
# Disruption webhook (if using POST /api/webhooks/disruption)
###########################
WEBHOOK_SECRET=

###########################
# Web Push (PWA — optional)
###########################
# Generate: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Optional; defaults to mailto:lohitkolluri@gmail.com
# VAPID_SUBJECT=mailto:you@yourdomain.com

###########################
# Optional / Production-required
###########################
# Required in production for redirects and links
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

GOV_ID_ENCRYPTION_KEY=
FACE_PHOTO_ENCRYPTION_KEY=
