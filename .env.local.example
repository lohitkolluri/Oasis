# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Weather & Environment
TOMORROW_IO_API_KEY=
# AQI: Open-Meteo (free, no key) used in adjudicator - no env var needed

# Maps & Traffic
GOOGLE_MAPS_API_KEY=

# News / Social Disruptions
NEWSDATA_IO_API_KEY=

# LLM (OpenRouter)
OPENROUTER_API_KEY=

# Payments — Razorpay (test keys for sandbox, live for production)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# When keys not set: PAYMENT_DEMO_MODE=true allows policy activation for dev
# PAYMENT_DEMO_MODE=

# Admin: comma-separated emails allowed to access /admin (empty = all authenticated users)
# ADMIN_EMAILS=admin@example.com,insurer@oasis.in
