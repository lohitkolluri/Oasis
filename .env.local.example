########################################
# Oasis .env.local.example
# Fill out required environment variables for local development.
# See README.md for setup instructions.
########################################

###########################
# Supabase Configuration
###########################
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

###########################
# Weather & Environment APIs
###########################
# Tomorrow.io – for weather-based disruptions (required)
TOMORROW_IO_API_KEY=

# AQI: WAQI is the preferred (ground station-based Air Quality Index).
# Register at https://aqicn.org/api/ for a token.
# Leave empty to fallback to Open-Meteo satellite data.
WAQI_API_KEY=

###########################
# Maps & Geocoding
###########################
# MapLibre uses OpenStreetMap tiles (public, no API key required)
# Nominatim (server-side) for reverse geocoding (no key required, 1 req/s limit)
# Google Maps NOT required.

###########################
# News & Disruption Detection
###########################
# NewsData.io API key (required for news-based trigger automation)
NEWSDATA_IO_API_KEY=

###########################
# AI & LLM (OpenRouter)
###########################
# Used for LLM-based adjudication and false-positive detection
OPENROUTER_API_KEY=

###########################
# Payments (Razorpay)
###########################
# Test keys for development/sandbox; live keys for production.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# For local/dev without Razorpay credentials, set PAYMENT_DEMO_MODE=true
# PAYMENT_DEMO_MODE=true

###########################
# Admin Access
###########################
# Comma-separated email addresses allowed into the /admin panel.
# At least one email required for initial admin access.
ADMIN_EMAILS=admin@example.com
