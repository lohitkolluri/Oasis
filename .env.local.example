########################################
# Oasis .env.local
# Copy: cp .env.local.example .env.local
# Fill required vars. See README.md for setup.
########################################

###########################
# Supabase (required)
###########################
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

###########################
# Admin (required)
###########################
ADMIN_EMAILS=admin@example.com

###########################
# Weather (Tomorrow.io – required for triggers)
###########################
TOMORROW_IO_API_KEY=

###########################
# News (NewsData.io – required for triggers)
###########################
NEWSDATA_IO_API_KEY=

###########################
# AQI (optional – fallback to Open-Meteo)
###########################
WAQI_API_KEY=

###########################
# AI (OpenRouter – adjudication, gov ID verification)
###########################
OPENROUTER_API_KEY=

###########################
# Payments (Stripe)
###########################
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Use sk_test_... from Stripe Dashboard → Developers → API keys for test payments

###########################
# Cron (required in production)
###########################
CRON_SECRET=

###########################
# Disruption webhook (if using POST /api/webhooks/disruption)
###########################
WEBHOOK_SECRET=

###########################
# Optional / Production-required
###########################
# Required in production for Stripe redirects and links
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

GOV_ID_ENCRYPTION_KEY=
FACE_PHOTO_ENCRYPTION_KEY=
